# Copy to `.env.local` for local overrides. Set these in your hosting provider for production.

# Required in production (min 16 characters). Sessions break if missing or changed between deploys.
AUTH_SECRET=

# Optional: single root for all persisted files (data/, uploads/, storage/). Use a mounted volume in Docker/systemd.
# OTA_DATA_DIR=/var/lib/ota

# Optional: comma-separated allowed browser origins for /api CORS. If wrong, cross-origin API calls fail.
# CORS_ORIGINS=https://ota.example.com

# Optional: max upload size in bytes (builds, profile uploads).
# MAX_UPLOAD_BYTES=

# Optional: override Secure flag on session cookies. Default: Secure in production (needs HTTPS).
# Set to 0 only for plain-HTTP debugging (not recommended public).
# AUTH_COOKIE_SECURE=1
